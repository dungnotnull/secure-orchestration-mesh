# Environment variables for secure-orchestration-mesh
# Copy to .env and customize

# ── Server ───────────────────────────────────────
SOM__SERVER__HOST=0.0.0.0
SOM__SERVER__PORT=50051

# ── LLM Provider ─────────────────────────────────
# ollama | claude | gpt4o
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic Claude (incident reports)
CLAUDE_API_KEY=

# OpenAI GPT-4o (fallback incident reports)
OPENAI_API_KEY=

# ── Anomaly Detection ────────────────────────────
SOM__ANOMALY__ISOLATION_FOREST__ENABLED=true
SOM__ANOMALY__ISOLATION_FOREST__SUSPICIOUS_THRESHOLD=0.65
SOM__ANOMALY__ISOLATION_FOREST__CRITICAL_THRESHOLD=0.85

SOM__ANOMALY__LSTM_AUTOENCODER__ENABLED=false

# ── Self-Update ──────────────────────────────────
SOM__SELF_UPDATE__ENABLED=false

# ── Database ─────────────────────────────────────
SOM__DATABASE__PATH=data/behavioral_metrics.db

# ── Telemetry ────────────────────────────────────
SOM__TELEMETRY__ENABLED=true
SOM__TELEMETRY__JAEGER__HOST=localhost
SOM__TELEMETRY__JAEGER__PORT=6831
